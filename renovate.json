{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
      "local>platform-mesh/.github:renovate-config"
    ],
    "packageRules": [
      {
        "matchManagers": ["gomod"],
        "matchDepTypes": ["replace"],
        "matchPackageNames": ["k8s.io/api", "k8s.io/apiserver", "k8s.io/client-go", "k8s.io/component-base"],
        "enabled": false
      }
    ],
    "customManagers": [
      {
        "customType": "regex",
        "fileMatch": [
          "(^|/)internal/subroutine/manifests/organizationIdp/repository\\.yaml$"
        ],
        "matchStrings": [
          "semver:\\s*\"?(?<currentValue>[\\d\\.]+(-[\\w\\.-]+)?)\"?"
        ],
        "versioningTemplate": "semver",
        "depNameTemplate": "ghcr.io/platform-mesh/helm-charts/organization-idp",
        "datasourceTemplate": "docker"
      }
    ]
}